NEWS_DATA_URL=https://storage.googleapis.com/ai-watch-feed-llm-watch-public/data/models.json
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=change-me
APP_ENV=development
FRONTEND_ORIGIN=http://localhost:5173
VOICEVOX_BASE_URL=http://localhost:50021
VOICEVOX_SPEAKER_ID=3
VOICEVOX_SPEAKER_ID_EXPERT=2
GEMINI_PROJECT=
GEMINI_LOCATION=us-central1
NEWS_SEARCH_REFRESH_ENABLED=true
NEWS_SEARCH_MODEL=gemini-2.5-flash
IMAGE_GEN_ENABLED=true
IMAGE_GEN_THUMBNAIL_MODEL=gemini-3-pro-image-preview
IMAGE_GEN_SLIDE_MODEL=gemini-2.5-flash-image
IMAGE_GEN_LOCATION=global
# セグメント導入イラストをVeo(image-to-video)で動かす。Veoは秒課金のため注意
# (fast 1080p $0.12/秒)。preview系はVertex AIで実行404になるためGA版(-001)を使う
VIDEO_GEN_ENABLED=true
VIDEO_GEN_MODEL=veo-3.1-fast-generate-001
VIDEO_GEN_LOCATION=us-central1
VIDEO_GEN_DURATION_SECONDS=8
VIDEO_GEN_OPENING_ENABLED=true
VIDEO_GEN_OPENING_MODEL=veo-3.1-generate-001
VIDEO_GEN_OPENING_TARGET_SECONDS=15
CHARACTER_OVERLAY_ENABLED=true
CHARACTER_OVERLAY_NAME=zundamon
BGM_ENABLED=true
BGM_FILE=
BGM_VOLUME_DB=-22.0
# YouTube自動アップロード(Feature D)。取得手順は docs/youtube-oauth.md を参照
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_UPLOAD_ENABLED=false

# 毎週金曜日 08:00(JST) に週次動画を自動生成し、SMTP でメール通知します。
WEEKLY_VIDEO_SCHEDULE_ENABLED=false
WEEKLY_VIDEO_SCHEDULE_TIMEZONE=Asia/Tokyo
WEEKLY_VIDEO_SCHEDULE_HOUR=8
WEEKLY_VIDEO_SCHEDULE_MINUTE=0
WEEKLY_VIDEO_NOTIFY_TO=
WEEKLY_VIDEO_NOTIFY_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
